# Tibetan Spirit AI Operations — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ─── Claude API ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Service Authentication ───────────────────────────────────────────────────
API_KEY=your-service-secret-for-cron-triggers

# ─── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_STORE_URL=tibetan-spirit.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_WEBHOOK_SECRET=whsec_...

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
# Note: Use the SERVICE key (bypasses RLS) for the agent system.
# Dashboard users get ANON key + RLS policies.

