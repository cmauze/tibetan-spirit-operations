{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(pm2 delete*)",
      "Bash(pm2 kill*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__shopify__.*|Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/budget-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-activity.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
