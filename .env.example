# Tibetan Spirit Ops — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Service role key (bypasses RLS — used by backend workflows only)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Public anon key (safe for frontend/dashboard use)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Shopify
# ─────────────────────────────────────────────────────────────────────────────
# Admin API access token for GraphQL Admin API (2026-01)
SHOPIFY_API_TOKEN=shpat_your-token-here

# Webhook HMAC verification secret
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret-here

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic
# ─────────────────────────────────────────────────────────────────────────────
# API key for Claude model calls (workflows + agents)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Slack
# ─────────────────────────────────────────────────────────────────────────────
# Bot token for ts_shared notifications (notify() helper)
SLACK_BOT_TOKEN=xoxb-your-token-here

# Incoming webhook URLs for direct Slack posting (slack-notify.sh hook)
SLACK_WEBHOOK_TS_ALERTS=https://hooks.slack.com/services/your/alerts/webhook
SLACK_WEBHOOK_TS_CUSTOMER_SERVICE=https://hooks.slack.com/services/your/cs/webhook

# Named channel IDs (used by workflow scripts)
SLACK_CHANNEL_OPS=C0123456789
SLACK_CHANNEL_CS=C0123456790
SLACK_CHANNEL_ALERTS=C0123456791

# ─────────────────────────────────────────────────────────────────────────────
# Notion
# ─────────────────────────────────────────────────────────────────────────────
# Used for Academy modules (Jothi training) and internal playbooks
NOTION_API_KEY=secret_your-notion-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Intercom (Helpdesk / CS)
# ─────────────────────────────────────────────────────────────────────────────
HELPDESK_PLATFORM=intercom
INTERCOM_ACCESS_TOKEN=your-intercom-access-token-here
INTERCOM_ADMIN_ID=your-intercom-admin-id-here
INTERCOM_WEBHOOK_SECRET=your-intercom-webhook-secret-here

# ─────────────────────────────────────────────────────────────────────────────
# Future integrations (graceful degradation if missing)
# ─────────────────────────────────────────────────────────────────────────────
# Email marketing
KLAVIYO_API_KEY=your-klaviyo-api-key-here

# Paid advertising
META_ADS_ACCESS_TOKEN=your-meta-ads-token-here
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-token-here

# SMS (reserved — not currently used; see marketing-discipline.md)
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
